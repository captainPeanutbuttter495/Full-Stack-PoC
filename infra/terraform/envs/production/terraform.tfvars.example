# PRODUCTION-LIKE MODE. Copy to terraform.tfvars and adjust. No secrets here.
# For a cheap, short-lived demo, copy demo.tfvars.example instead.
region              = "us-west-2"
ecr_repository_name = "pwyw-web"
ecr_force_delete    = false # keep images safe; do not auto-delete on destroy

# --- Network (private nodes behind NAT) ---
vpc_cidr                   = "10.0.0.0/16"
azs                        = ["us-west-2a", "us-west-2b", "us-west-2c"]
private_subnets            = ["10.0.0.0/20", "10.0.16.0/20", "10.0.32.0/20"]
public_subnets             = ["10.0.48.0/20", "10.0.64.0/20", "10.0.80.0/20"]
enable_nat_gateway         = true
single_nat_gateway         = true
enable_s3_gateway_endpoint = true
worker_nodes_public        = false # private nodes

# --- EKS (2× on-demand for availability + rolling updates) ---
cluster_name        = "pwyw"
cluster_version     = "1.30"
node_instance_types = ["t3.medium"]
node_capacity_type  = "ON_DEMAND"
node_min_size       = 2
node_max_size       = 4
node_desired_size   = 2

# Grant the CI deploy role (bootstrap/github-oidc output) kubectl access:
# eks_access_entries = {
#   ci = {
#     principal_arn = "arn:aws:iam::<account-id>:role/pwyw-github-actions-deploy"
#     policy_associations = {
#       admin = {
#         policy_arn   = "arn:aws:eks::aws:cluster-access-policy/AmazonEKSClusterAdminPolicy"
#         access_scope = { type = "cluster" }
#       }
#     }
#   }
# }

# --- IRSA placeholders (narrow once secrets/storage phases exist) ---
# secrets_manager_arns         = ["arn:aws:secretsmanager:us-west-2:<account-id>:secret:pwyw/*"]
# documents_bucket_object_arns = ["arn:aws:s3:::pwyw-documents/*"]

tags = {
  Project     = "pwyw"
  ManagedBy   = "terraform"
  Environment = "production"
}
