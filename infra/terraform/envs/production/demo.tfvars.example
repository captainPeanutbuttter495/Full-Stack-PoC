# DEMO MODE — cheapest short-lived deployment (~1 week, then terraform destroy).
# Copy to terraform.tfvars for a demo run:  cp demo.tfvars.example terraform.tfvars
#
# Differences from production-like mode:
#   - No NAT gateway (nodes run in PUBLIC subnets, reach ECR via the free IGW)
#   - 1× t3.small SPOT node instead of 2× t3.medium on-demand
#   - ECR force_delete = true so `terraform destroy` doesn't snag on images
# See Deployment/AWS.md "Short-Lived Demo Deployment" for cost + teardown.
region              = "us-west-2"
ecr_repository_name = "pwyw-web"
ecr_force_delete    = true # DEMO-ONLY: lets destroy remove the repo with images

# --- Network (public nodes, NO NAT) ---
vpc_cidr                   = "10.0.0.0/16"
azs                        = ["us-west-2a", "us-west-2b"]
private_subnets            = ["10.0.0.0/20", "10.0.16.0/20"]
public_subnets             = ["10.0.48.0/20", "10.0.64.0/20"]
enable_nat_gateway         = false # saves ~$7.56/week
single_nat_gateway         = true  # ignored when NAT is disabled
enable_s3_gateway_endpoint = true  # free; keeps S3 traffic off the public path
worker_nodes_public        = true  # nodes in public subnets, get public IPs

# --- EKS (single cheap Spot node) ---
cluster_name        = "pwyw"
cluster_version     = "1.30"
node_instance_types = ["t3.small"]
node_capacity_type  = "SPOT"
node_min_size       = 1
node_max_size       = 2
node_desired_size   = 1

# Helm add-ons (ALB controller + ESO). First apply tip if a provider error occurs:
#   terraform apply -target=module.network -target=module.eks   # then full apply
install_eks_addons = true

# --- DNS / TLS (kept for the demo: real HTTPS + domain) ---
enable_dns_tls         = true
domain_name            = "example.com"             # your registered domain
hosted_zone_id         = "Z0123456789ABCDEFGHIJK"  # your Route 53 zone ID
app_hostname           = "demo.example.com"         # demo app host
create_acm_certificate = true
acm_certificate_arn    = ""

# --- Secrets Manager + S3/CloudFront downloads (force_destroy for clean teardown) ---
enable_secrets          = true
secrets_prefix          = "pwyw"
enable_storage_cdn      = true
documents_bucket_name   = "pwyw-documents-demo-REPLACE-ME" # globally unique
documents_force_destroy = true                              # DEMO-ONLY clean teardown
cloudfront_price_class  = "PriceClass_100"
