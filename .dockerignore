# Dependencies — reinstalled inside the image from the lockfile
node_modules
.pnp
.pnp.*

# Build output — regenerated by `next build` in the image
.next
out
build

# Generated Prisma client — regenerated by `prisma generate` in the image
lib/generated/prisma

# Secrets and env files — never copy into the build context
.env
.env.*

# Version control / CI / tooling
.git
.gitignore
.github
.vercel

# Tests and reports — not needed at build/runtime.
# playwright.config.ts is excluded too: its e2e/ tests aren't in the image, and it
# imports @next/env (a transitive dep not resolvable under pnpm), which would
# otherwise fail `next build`'s project-wide type check.
e2e
tests
playwright.config.ts
playwright-report
test-results
coverage

# Editor / agent / docs scratch
.vscode
.idea
.obsidian
.windsurf
.claude
.agents
.design-reference
FullStack-PWYW
*.md
!README.md

# Docker
Dockerfile
.dockerignore

# OS noise
.DS_Store
